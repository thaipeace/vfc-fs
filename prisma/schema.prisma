generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  SALE
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum DiagnosisStatus {
  PROCESSING
  DONE
  FAILED
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  phone       String   @unique               // primary identifier, Zalo-linked
  zaloId      String?  @unique               // Zalo OpenID
  name        String?
  avatarUrl   String?
  role        Role     @default(FARMER)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  farmerProfile FarmerProfile?
  saleProfile   SaleProfile?
  orders        Order[]
  diagnoses     PlantDiagnosis[]
  chatMessages  ChatMessage[]
  otpRequests   OtpRequest[]

  @@index([phone])
  @@index([zaloId])
  @@index([role])
  @@map("users")
}

model FarmerProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  province   String?
  district   String?
  ward       String?
  farmSize   Float?  // hectares
  cropTypes  String[] // e.g. ["rice", "coffee"]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("farmer_profiles")
}

model SaleProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  region      String?
  managedOrders Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sale_profiles")
}

// ─── OTP ──────────────────────────────────────────────────────────────────────

model OtpRequest {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone     String
  otp       String   // hashed
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@map("otp_requests")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  slug        String   @unique
  description String?
  imageUrls   String[]
  price       Decimal  @db.Decimal(12, 2)
  unit        String   @default("kg")
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        String[]  // for AI suggestion matching

  orderItems  OrderItem[]
  diagnoses   DiagnosisSuggestion[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  saleId       String?
  sale         SaleProfile? @relation(fields: [saleId], references: [id])
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12, 2)
  note         String?
  deliveryAddr Json?       // { province, district, ward, address }
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([saleId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  @@map("order_items")
}

// ─── Plant Diagnosis (AI) ─────────────────────────────────────────────────────

model PlantDiagnosis {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  imageUrls     String[]
  cropType      String?
  rawAiResponse Json?
  summary       String?         // AI plain-text diagnosis
  confidence    Float?          // 0-1
  status        DiagnosisStatus @default(PROCESSING)
  suggestions   DiagnosisSuggestion[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("plant_diagnoses")
}

model DiagnosisSuggestion {
  id          String         @id @default(cuid())
  diagnosisId String
  diagnosis   PlantDiagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?       @relation(fields: [productId], references: [id])
  reason      String?        // Why this product is suggested
  rank        Int            @default(1)
  createdAt   DateTime       @default(now())

  @@map("diagnosis_suggestions")
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  toUserId  String?  // null = broadcast / AI
  content   String
  mediaUrl  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([toUserId])
  @@index([createdAt])
  @@map("chat_messages")
}
